# ── LLM 配置 ──
MODEL=gpt-4o-mini
BASE_URL=https://api.deepseek.com
API_KEY=sk-xxx

# ── 数据源 ──
TUSHARE_TOKEN=your_token_here
# FINNHUB_API_KEY=your_key_here

# ── 市场数据源声明（默认 yfinance，零配置即可用）──
# MARKET_CN=tushare              # A 股：tushare / yfinance
# MARKET_US=yfinance             # 美股：yfinance / finnhub

# ── 工作区（可选，默认 ~/.agent/workspace）──
# WORKSPACE=~/.agent/workspace

# ── 系统状态（可选：sessions/traces 等，默认 ~/.agent/state）──
# STATE_DIR=~/.agent/state

# ── Session 裁剪（可选，默认 20）──
# SESSION_KEEP_LAST_USER_MESSAGES=20

# ── 高风险能力开关（可选，默认关闭）──
# ENABLE_BASH=false

# ── Telegram（可选）──
# TELEGRAM_BOT_TOKEN=123456:abcdef
# TELEGRAM_ALLOWED_USER_IDS=123456789
# TELEGRAM_SHOW_PROCESS_MESSAGES=false
# TELEGRAM_STATUS_EDIT_THROTTLE_SEC=1.0
# TELEGRAM_CONFIRM_TIMEOUT_SEC=60
# TELEGRAM_DROP_PENDING_UPDATES=true
# TELEGRAM_RENDER_MODE=html
