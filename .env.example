# ── AthenaClaw 应用配置 ──
ATHENACLAW_MODEL=gpt-4o-mini
ATHENACLAW_BASE_URL=https://api.deepseek.com
ATHENACLAW_API_KEY=sk-xxx

# ── 工作区与运行状态（可选）──
# ATHENACLAW_WORKSPACE=~/.athenaclaw/workspace
# ATHENACLAW_STATE_DIR=~/.athenaclaw/state

# ── 运行参数（可选）──
# ATHENACLAW_MARKET_CN=yfinance
# ATHENACLAW_MARKET_US=yfinance
# ATHENACLAW_ENABLE_BASH=false
# ATHENACLAW_CONTEXT_WINDOW=100000
# ATHENACLAW_COMPACT_RECENT_TURNS=3
# ATHENACLAW_SESSION_KEEP_LAST_USER_MESSAGES=20
# ATHENACLAW_SEARCH_PROVIDER=tavily
# ATHENACLAW_IMAGE_DETAIL=low
# ATHENACLAW_AUTOMATION_DEFAULT_TIMEZONE=Asia/Shanghai
# ATHENACLAW_AUTOMATION_TASK_SCAN_SEC=30

# ── 数据源 ──
TUSHARE_TOKEN=your_token_here
# FINNHUB_API_KEY=your_key_here
# TAVILY_API_KEY=your_key_here

# ── Telegram（可选）──
# TELEGRAM_BOT_TOKEN=123456:abcdef
# TELEGRAM_ALLOWED_USER_IDS=123456789
# TELEGRAM_SHOW_PROCESS_MESSAGES=false
# TELEGRAM_STATUS_EDIT_THROTTLE_SEC=1.0
# TELEGRAM_CONFIRM_TIMEOUT_SEC=60
# TELEGRAM_DROP_PENDING_UPDATES=true
# TELEGRAM_RENDER_MODE=html

# ── Discord（可选，DM-only）──
# DISCORD_BOT_TOKEN=your_bot_token_here
# DISCORD_ALLOWED_USER_IDS=123456789012345678
# DISCORD_SHOW_PROCESS_MESSAGES=false
# DISCORD_STATUS_EDIT_THROTTLE_SEC=1.0
# DISCORD_CONFIRM_TIMEOUT_SEC=60
