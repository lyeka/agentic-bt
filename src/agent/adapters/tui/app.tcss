/* ── InvestmentApp — TUI 终端界面样式 ── */

/* ── 主布局 ─────────────────────────────── */

#main {
    height: 1fr;
}

#chat {
    width: 3fr;
    padding: 0 1;
}

/* ── 侧边栏 ─────────────────────────────── */

#sidebar {
    width: 1fr;
    min-width: 24;
    max-width: 40;
    border-left: solid $accent;
    padding: 1 0 0 0;
}

#sidebar-tabs {
    height: 1fr;
}

.sb-section {
    margin: 0 1 1 1;
}

/* ── 输入区 ──────────────────────────────── */

#input {
    height: auto;
    min-height: 3;
    max-height: 8;
    dock: bottom;
    border-top: solid $accent;
}

/* ── 消息 ────────────────────────────────── */

.user-msg {
    background: $primary-background;
    padding: 0 1;
    margin: 1 0 0 8;
    border: round $primary;
}

.assistant-msg {
    padding: 0 1;
    margin: 1 8 0 0;
}

.msg-meta {
    color: $text-muted;
    text-style: dim;
    padding: 0 1;
    margin: 0 8 0 0;
    text-align: right;
}

/* ── 工具状态 ────────────────────────────── */

.tool-status {
    color: $text-muted;
    padding: 0 1;
    margin: 0 8 0 2;
}

.thinking {
    color: $text-muted;
    padding: 0 1;
    margin: 0 8 0 2;
}
